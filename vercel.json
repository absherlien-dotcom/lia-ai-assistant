{
  "version": 2,
  "rewrites": [
    {
      "source": "/api/config",
      "destination": "/api/index?route=config"
    },
    {
      "source": "/api/google-login",
      "destination": "/api/index?route=google-login"
    },
    {
      "source": "/api/logout",
      "destination": "/api/index?route=logout"
    },
    {
      "source": "/api/auth-check",
      "destination": "/api/index?route=auth-check"
    },
    {
      "source": "/api/health",
      "destination": "/api/index?route=health"
    },
    {
      "source": "/api/chat",
      "destination": "/api/index?route=chat"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-store, max-age=0"
        },
        {
          "key": "Cross-Origin-Opener-Policy",
          "value": "same-origin-allow-popups"
        }
      ]
    }
  ]
}